#   3. Generated block: subcommand tree + per-leaf flag completions
#
# Regenerate the generated block with:
#   ./generate.py

# ---------- Helpers ----------

function __fish_knife_tokens
    set -l tokens (commandline -opc)
    set -e tokens[1]
    for t in $tokens
        string match -q -- "-*" $t; or echo $t
    end
end

function __fish_knife_cmd_path
    set -l tokens (__fish_knife_tokens)
    set -l n (count $tokens)
    test $n -eq 0; and echo ""; and return
    for i in (seq $n -1 1)
        set -l candidate (string join " " $tokens[1..$i])
        if contains -- $candidate $__fish_knife_paths
            echo $candidate
            return
        end
    end
    echo ""
end

function __fish_knife_path_is
    test (__fish_knife_cmd_path) = "$argv"
end

